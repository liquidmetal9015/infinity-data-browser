{
  "openapi": "3.1.0",
  "info": {
    "title": "Infinity Data API",
    "version": "0.1.0"
  },
  "components": {
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "ok"
            ]
          },
          "version": {
            "type": "string"
          }
        },
        "required": [
          "status",
          "version"
        ]
      },
      "ArmyListSummary": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": [
              "string",
              "null"
            ]
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "rating": {
            "type": "integer"
          },
          "faction_id": {
            "type": "integer"
          },
          "points": {
            "type": "integer"
          },
          "swc": {
            "type": "number"
          },
          "unit_count": {
            "type": "integer"
          },
          "is_locked": {
            "type": "boolean"
          },
          "created_at": {
            "type": "string"
          },
          "updated_at": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "name",
          "description",
          "tags",
          "rating",
          "faction_id",
          "points",
          "swc",
          "unit_count",
          "is_locked",
          "created_at",
          "updated_at"
        ]
      },
      "Error": {
        "type": "object",
        "properties": {
          "detail": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "array",
                "items": {}
              }
            ]
          }
        },
        "required": [
          "detail"
        ]
      },
      "ArmyListDetail": {
        "allOf": [
          {
            "$ref": "#/components/schemas/ArmyListSummary"
          },
          {
            "type": "object",
            "properties": {
              "units_json": {
                "$ref": "#/components/schemas/UnitsJson"
              }
            },
            "required": [
              "units_json"
            ]
          }
        ]
      },
      "UnitsJson": {
        "type": "object",
        "additionalProperties": {}
      },
      "ArmyListCreate": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "maxLength": 255
          },
          "description": {
            "type": [
              "string",
              "null"
            ]
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          },
          "rating": {
            "type": "integer",
            "minimum": 0,
            "maximum": 5,
            "default": 0
          },
          "faction_id": {
            "type": "integer"
          },
          "points": {
            "type": "integer",
            "default": 0
          },
          "swc": {
            "type": "number",
            "default": 0
          },
          "units_json": {
            "$ref": "#/components/schemas/UnitsJson"
          }
        },
        "required": [
          "name",
          "faction_id"
        ]
      },
      "ArmyListUpdate": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "maxLength": 255
          },
          "description": {
            "type": [
              "string",
              "null"
            ]
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "rating": {
            "type": "integer",
            "minimum": 0,
            "maximum": 5
          },
          "faction_id": {
            "type": "integer"
          },
          "points": {
            "type": "integer"
          },
          "swc": {
            "type": "number"
          },
          "units_json": {
            "$ref": "#/components/schemas/UnitsJson"
          }
        }
      },
      "ChatResponse": {
        "type": "object",
        "properties": {
          "reply": {
            "type": "string"
          },
          "tools_used": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "input_tokens": {
            "type": "integer"
          },
          "output_tokens": {
            "type": "integer"
          }
        },
        "required": [
          "reply",
          "tools_used",
          "input_tokens",
          "output_tokens"
        ]
      },
      "ChatRequest": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "maxLength": 2000
          },
          "history": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ChatMessage"
            },
            "maxItems": 20
          },
          "context": {
            "$ref": "#/components/schemas/ChatContext"
          }
        },
        "required": [
          "message"
        ]
      },
      "ChatMessage": {
        "type": "object",
        "properties": {
          "role": {
            "type": "string",
            "enum": [
              "user",
              "assistant"
            ]
          },
          "content": {
            "type": "string"
          }
        },
        "required": [
          "role",
          "content"
        ]
      },
      "ChatContext": {
        "type": "object",
        "properties": {
          "faction_id": {
            "type": [
              "integer",
              "null"
            ]
          },
          "faction_name": {
            "type": [
              "string",
              "null"
            ]
          },
          "list_points": {
            "type": [
              "number",
              "null"
            ]
          },
          "list_swc": {
            "type": [
              "number",
              "null"
            ]
          },
          "list_units": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ListContextUnit"
            }
          }
        }
      },
      "ListContextUnit": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "isc": {
            "type": "string"
          },
          "loadout": {
            "type": "string"
          },
          "points": {
            "type": "number"
          },
          "swc": {
            "type": "number"
          }
        },
        "required": [
          "name",
          "isc"
        ]
      }
    },
    "parameters": {}
  },
  "paths": {
    "/api/health": {
      "get": {
        "tags": [
          "health"
        ],
        "summary": "Liveness check",
        "responses": {
          "200": {
            "description": "Server is running",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/lists": {
      "get": {
        "tags": [
          "lists"
        ],
        "summary": "List the authenticated user's army lists",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ArmyListSummary"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "lists"
        ],
        "summary": "Create an army list",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ArmyListCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ArmyListDetail"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "422": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/lists/{listId}": {
      "get": {
        "tags": [
          "lists"
        ],
        "summary": "Get an army list by ID",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "pattern": "^\\d+$"
            },
            "required": true,
            "name": "listId",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ArmyListDetail"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "lists"
        ],
        "summary": "Update an army list",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "pattern": "^\\d+$"
            },
            "required": true,
            "name": "listId",
            "in": "path"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ArmyListUpdate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ArmyListDetail"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "422": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "lists"
        ],
        "summary": "Delete an army list",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "pattern": "^\\d+$"
            },
            "required": true,
            "name": "listId",
            "in": "path"
          }
        ],
        "responses": {
          "204": {
            "description": "Deleted"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/agent/chat": {
      "post": {
        "tags": [
          "agent"
        ],
        "summary": "Chat with the Infinity AI agent",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChatRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Reply",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChatResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "422": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "429": {
            "description": "Rate limited",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "503": {
            "description": "AI provider unavailable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "webhooks": {}
}
