{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "noEmit": false,
        "outDir": "dist",
        "rootDir": "..",
        "declaration": false,
        "sourceMap": false
    },
    "include": ["src/**/*"],
    "exclude": ["tests/**/*", "**/*.test.ts"],
    "tsc-alias": {
        "resolveFullPaths": true,
        "verbose": false
    }
}
