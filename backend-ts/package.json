{
    "name": "@infinity-data/backend",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
        "start": "node dist/backend-ts/src/index.js",
        "typecheck": "tsc --noEmit",
        "lint": "eslint .",
        "test": "vitest run",
        "test:watch": "vitest",
        "db:introspect": "drizzle-kit introspect"
    },
    "dependencies": {
        "@anthropic-ai/sdk": "^0.39.0",
        "@hono/node-server": "^1.19.14",
        "@hono/zod-openapi": "^0.18.4",
        "@hono/zod-validator": "^0.4.2",
        "drizzle-orm": "^0.45.2",
        "firebase-admin": "^13.0.2",
        "hono": "^4.6.14",
        "pg": "^8.13.1",
        "zod": "^3.24.1"
    },
    "devDependencies": {
        "@types/node": "^22.10.5",
        "@types/pg": "^8.11.10",
        "drizzle-kit": "^0.31.10",
        "eslint": "^9.17.0",
        "tsc-alias": "^1.8.17",
        "tsx": "^4.19.2",
        "typescript": "^5.7.2",
        "typescript-eslint": "^8.19.0",
        "vitest": "^2.1.8"
    }
}
