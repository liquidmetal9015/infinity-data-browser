    "/api/search": {
      "get": {
        "tags": [
          "search"
        ],
        "summary": "Search Units",
        "description": "Search units with text query and/or attribute filters.\n\nFilters are ANDed together. Text search matches name and ISC (case-insensitive).\nItem filters use the JSONB arrays on profiles and loadouts.",
        "operationId": "search_units_api_search_get",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Text search query (name or ISC)",
              "title": "Q"
            },
            "description": "Text search query (name or ISC)"
          },
          {
            "name": "faction",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Filter by faction slug",
              "title": "Faction"
            },
            "description": "Filter by faction slug"
          },
          {
            "name": "has_weapon",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Filter by weapon ID",
              "title": "Has Weapon"
            },
            "description": "Filter by weapon ID"
          },
          {
            "name": "has_skill",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Filter by skill ID",
              "title": "Has Skill"
            },
            "description": "Filter by skill ID"
          },
          {
            "name": "has_equipment",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Filter by equipment ID",
              "title": "Has Equipment"
            },
            "description": "Filter by equipment ID"
          },
          {
            "name": "min_points",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Minimum points cost",
              "title": "Min Points"
            },
            "description": "Minimum points cost"
          },
          {
            "name": "max_points",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Maximum points cost",
              "title": "Max Points"
            },
            "description": "Maximum points cost"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 200,
              "minimum": 1,
              "default": 50,
              "title": "Limit"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 0,
              "default": 0,
              "title": "Offset"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
